{
  "name": "research-to-action",
  "version": "1.1.0",
  "description": "Research-driven decision pipeline — chains research_discover, research_add, research_analyze, consensus_vote, memory_query",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexus-substrate/research-to-action.git"
  },
  "keywords": [
    "nexus-agents",
    "mcp",
    "e2e-testing",
    "research",
    "consensus-voting",
    "multi-agent"
  ],
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "live": "NEXUS_LIVE=true tsx src/run-live.ts"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.6",
    "zod": "^3.24.0"
  }
}
